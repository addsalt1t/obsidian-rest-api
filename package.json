{
  "name": "obsidian-rest-api",
  "version": "1.0.0",
  "description": "Extended REST API plugin for Obsidian",
  "main": "main.js",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "npm run build:types && node esbuild.config.mjs production",
    "build:types": "npm run build -w @obsidian-workspace/shared-types",
    "contract:export": "npm run build:types && node scripts/export-parity-contract.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:submission": "vitest run tests/unit/compliance/submission-requirements.test.ts",
    "test:dead-code": "vitest run tests/unit/dead-code.test.ts",
    "test:hotspots": "npm run test -- tests/unit/services/vector-service.test.ts tests/unit/services/autolink-service.test.ts tests/unit/routes/vault-tree-regression.test.ts",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "version": "node version-bump.mjs && git add manifest.json versions.json"
  },
  "keywords": [
    "obsidian",
    "rest-api",
    "dataview"
  ],
  "author": "jedi",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/json-logic-js": "^2.0.8",
    "@types/node": "^20.10.0",
    "@types/node-forge": "^1.3.14",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "@vitest/coverage-v8": "^4.0.18",
    "builtin-modules": "^5.0.0",
    "esbuild": "^0.27.2",
    "eslint": "^9.39.2",
    "lint-staged": "^16.2.7",
    "obsidian": "latest",
    "supertest": "^7.2.2",
    "tslib": "^2.6.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.54.0",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@obsidian-workspace/shared-types": "*",
    "cors": "^2.8.5",
    "express": "^4.21.1",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.1.0",
    "json-logic-js": "^2.0.5",
    "lru-cache": "^11.2.5",
    "node-forge": "^1.3.3",
    "safe-regex": "^2.1.1",
    "zod": "^3.24.1"
  }
}
